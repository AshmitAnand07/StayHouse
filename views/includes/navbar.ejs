<link rel="stylesheet" href="/css/navbar.css"> <!-- link style file -->

<nav class="nav-box">
  <div id="nav-main">
    <div id="nav-main-bar">
      <div class="nav-icon">
        <a href="/listings"><img class="imgAirbnb" src="/Icon/name-logo.png" alt="Airbnb"></a>
      </div>
      <div class="nav-search nav-hover nav-search-search">
        <form class="d-flex needs-validation" role="search" action="/listings/search" method="get" id="searchBox">
          <input type="search" placeholder="Search" aria-label="Search" name="q" id="mySearchInput">
          <button type="submit" id="search"><i class="fa-solid fa-magnifying-glass"></i></i></button>
        </form>
      </div>

      <!-- Right side nav actions -->
      <div class="nav-right">
        <!-- "Airbnb your home" — always visible -->
        <a href="/listings/new" class="nav-host-btn" id="airbnb-your-home-btn">
          <i class="fa-solid fa-house-chimney"></i>
          Airbnb your home
        </a>

        <!-- Logged OUT: show Login & Signup inline -->
        <% if (typeof currUser === 'undefined' || !currUser) { %>
          <a href="/login" class="nav-auth-btn nav-login-btn" id="nav-login-link">Log in</a>
          <a href="/signup" class="nav-auth-btn nav-signup-btn" id="nav-signup-link">Sign up</a>
        <% } %>

        <!-- User avatar / dropdown trigger -->
        <div class="nav-user nav-hover" id="nav-user-trigger">
          <div>
            <img src="/Icon/navbar-icon.png" id="png-img-bar">
            <% if (typeof currUser !== 'undefined' && currUser && currUser.image && currUser.image.url) { %>
              <img src="<%= currUser.image.url %>" alt="Profile" id="png-img-user">
            <% } else { %>
              <img src="/Icon/navbar-icon-user.png" alt="User" id="png-img-user">
            <% } %>
            <img src="/Icon/navbar-icon-cross.png" id="png-img-cross">
          </div>
        </div>

        <!-- Dropdown: only Profile & Logout when logged in -->
        <div class="user-fnx" style="display: none;">
          <% if (typeof currUser !== 'undefined' && currUser) { %>
            <a href="/profile"><i class="fa-solid fa-user"></i> &nbsp;Profile</a>
            <a href="/listings/new"><i class="fa-solid fa-plus"></i> &nbsp;New Listing</a>
            <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> &nbsp;Log out</a>
          <% } else { %>
            <a href="/signup"><i class="fa-solid fa-user-plus"></i> &nbsp;Sign up</a>
            <a href="/login"><i class="fa-solid fa-right-to-bracket"></i> &nbsp;Log in</a>
          <% } %>
        </div>
      </div><!-- end .nav-right -->

    </div>
    <div id="nav-search-hide">
      <div class="nav-search nav-hover">
        <form class="d-flex needs-validation" role="search" action="/listings/search" method="get" id="searchBox">
          <input type="search" placeholder="Search" aria-label="Search" name="q" id="mySearchInput">
          <button type="submit" id="search"><i class="fa-solid fa-magnifying-glass"></i></i></button>
        </form>
      </div>
    </div>
  </div>
</nav>
<script src="/js/navbar.js"></script>